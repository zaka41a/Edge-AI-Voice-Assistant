# AI backend: "cloud" (Grok / xAI) or "local" (Ollama)
EDGEAI_LLM=local

# Grok (xAI) - required when EDGEAI_LLM=cloud
XAI_API_KEY=
EDGEAI_GROK_MODEL=grok-2-latest

# Ollama (local) - used when EDGEAI_LLM=local
OLLAMA_BASE_URL=http://localhost:11434/v1
# Set to a model you have pulled (run: ollama list). e.g. mistral:latest, llama3.1:8b
EDGEAI_OLLAMA_MODEL=mistral:latest

# PostgreSQL
EDGEAI_DSN=postgresql://edgeai:edgeai@localhost:5544/edgeai
